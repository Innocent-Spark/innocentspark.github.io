---
layout: base.njk
title: Portuguese Riverside Co-Living Project
bodyClass: "bg-gray-100 text-gray-900"
externalStyles:
  - https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css
pageScripts: []
customStyles: |
    /* Styles for the updates section */
    .update-entry {
        border-left: 4px solid #16a34a;
        padding-left: 1rem;
        margin-bottom: 2rem;
    }
    
    .update-date {
        font-weight: 600;
        color: #16a34a;
        margin-bottom: 0.5rem;
    }
    
    /* Ensure proper paragraph formatting */
    section p {
        margin-bottom: 1rem;
    }
    
    section h1 {
        font-size: 1.875rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }
    
    section h2 {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        margin-top: 1.5rem;
    }
    
    /* Fix bullet points display */
    section ul {
        list-style-type: disc !important;
        margin-left: 2rem !important;
        margin-bottom: 1.5rem !important;
        padding-left: 1rem !important;
    }
    
    section ol {
        list-style-type: decimal !important;
        margin-left: 2rem !important;
        margin-bottom: 1.5rem !important;
        padding-left: 1rem !important;
    }
    
    section li {
        margin-bottom: 0.5rem !important;
        display: list-item !important;
        list-style-position: outside !important;
    }
    
    section a {
        color: #16a34a;
        text-decoration: underline;
    }
    
    .home-link {
        display: inline-block;
        margin-bottom: 1rem;
        color: #16a34a;
        text-decoration: underline;
        font-weight: 600;
    }
---
<div class="container mx-auto px-4 py-4">
    <a href="/" class="home-link">← Back to Home</a>
</div>

<header class="bg-green-600 text-white py-6">
    <div class="container mx-auto px-4">
        <h1 class="text-3xl font-bold">{{ portugal.meta.title }}</h1>
        <p class="mt-2">{{ portugal.meta.headerText | markdown | safe }}</p>
    </div>
</header>

<main class="container mx-auto px-4 py-8">
    {% for section in portugal.meta.sections %}
        {% set content = portugal[section] %}
        <section class="mb-8">
            {{ content | safe }}
        </section>
    {% endfor %}
    
    <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Gallery</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            <!-- Images -->
            {% for image in media.images %}
            <img src="{{ image.path }}" alt="{{ image.alt }}" class="w-full h-auto" loading="lazy">
            {% endfor %}
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mt-4">
            <!-- Videos -->
            {% for video in media.videos %}
            <video src="{{ video.path }}" controls class="w-full h-auto" preload="none"></video>
            {% endfor %}
        </div>
    </section>

    <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Location</h2>
        <p class="mb-4">Come and visit!:</p>
        <div class="aspect-w-16 aspect-h-9">
            <iframe src="{{ portugal.meta.mapEmbedUrl }}" width="100%" height="480" frameborder="0" style="border:0;" allowfullscreen="" aria-hidden="false" tabindex="0"></iframe>
        </div>
    </section>
</main>

<footer class="bg-gray-800 text-white py-4">
    <div class="container mx-auto px-4 text-center">
        <!-- <p>&copy; 2024 Portuguese Riverside Co-Living Project. All Rights Reserved.</p> -->
    </div>
</footer> 